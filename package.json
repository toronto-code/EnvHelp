{
  "name": "envhelper",
  "version": "0.1.0",
  "description": "Local-first .env setup, audit, and sharing for solo builders and small teams.",
  "type": "module",
  "bin": {
    "envhelper": "./src/cli.js"
  },
  "files": [
    "src",
    "providers",
    "README.md",
    "SECURITY.md",
    "THREAT_MODEL.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node ./src/cli.js start",
    "doctor": "node ./src/cli.js doctor",
    "providers": "node ./src/cli.js providers",
    "providers:audit": "node ./scripts/audit-providers.js",
    "check": "npm test",
    "test": "node --test && node ./scripts/audit-providers.js"
  },
  "keywords": [
    "env",
    "dotenv",
    "api-keys",
    "secrets",
    "hackathon",
    "cli",
    "age-encryption"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toronto-code/EnvHelper.git"
  },
  "bugs": {
    "url": "https://github.com/toronto-code/EnvHelper/issues"
  },
  "homepage": "https://github.com/toronto-code/EnvHelper#readme",
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
